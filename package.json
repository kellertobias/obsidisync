{
  "name": "obsidian-ios-git-sync",
  "version": "0.1.0",
  "description": "Obsidian sync plugin for iOS, iPadOS, and macOS plus a low-footprint server-side Git worker.",
  "main": "main.js",
  "scripts": {
    "build": "npm run build:plugin && npm run build:server",
    "build:plugin": "tsc -p tsconfig.json --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "build:server": "cargo build --manifest-path rust-server/Cargo.toml --release",
    "dev": "node esbuild.config.mjs",
    "start:server": "cargo run --manifest-path rust-server/Cargo.toml",
    "test": "npm run test:plugin && npm run build:plugin && npm run test:server",
    "test:plugin": "node -e \"require('fs').rmSync('.tmp-tests',{recursive:true,force:true})\" && tsc -p tsconfig.test.json && node --test .tmp-tests/tests/*.test.js",
    "test:server": "cargo test --manifest-path rust-server/Cargo.toml"
  },
  "keywords": [
    "obsidian",
    "git",
    "ios",
    "ipad"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "typescript": "^5.4.5"
  }
}
