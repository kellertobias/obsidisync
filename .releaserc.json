{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "npm version ${nextRelease.version} --no-git-tag-version --allow-same-version && node scripts/sync-version.mjs ${nextRelease.version}"
      }
    ],
    [
      "@saithodev/semantic-release-gitea",
      {
        "assets": [{ "path": "main.js" }, { "path": "manifest.json" }]
      }
    ]
  ]
}
